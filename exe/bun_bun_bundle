#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bun_bun_bundle'

command = ARGV[0]
flags = ARGV[1..]
bun_dir = BunBunBundle.bun_path
bake = File.join(bun_dir, 'bake.js')

case command
when 'dev', 'watch'
  exec('bun', 'run', bake, '--dev', *flags)
when 'build'
  exec('bun', 'run', bake, *flags)
else
  puts <<~USAGE
    Usage: bun_bun_bundle <command> [flags]

    Commands:
      dev     Start development server with live reload and CSS hot-reloading
      build   Build assets

    Flags:
      --prod              Shortcut for --fingerprint --minify
      --fingerprint       Hash asset filenames for cache busting
      --minify            Minify JS and CSS output
      --sourcemap[=KIND]  Sourcemap kind: inline, linked, external, none
                          (dev defaults to inline, builds default to linked)
      --sri[=ALGOS]       Compute Subresource Integrity digests for each
                          asset (comma-separated: sha256, sha384, sha512;
                          defaults to sha384)
      --debug             Enable verbose WebSocket logging

    Examples:
      bun_bun_bundle dev                            # live reload
      bun_bun_bundle build                          # plain build
      bun_bun_bundle build --prod                   # fingerprint + minify
      bun_bun_bundle build --fingerprint            # fingerprint only
      bun_bun_bundle build --prod --sri=sha384      # add integrity digests
      bun_bun_bundle build --prod --sourcemap=none  # strip sourcemaps

    Configuration:
      Place a config/bun.json in your project root to customize settings.
      See the README for available options.
  USAGE
  exit(command ? 1 : 0)
end
